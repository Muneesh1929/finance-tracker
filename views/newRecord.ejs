<% layout("layouts/boilerplate") %>

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card shadow">
            <div class="card-body">

                <h3 class="mb-4 text-center">Add New Record</h3>

                <form action="/api/records" method="POST">

                    <!-- Amount -->
                    <div class="mb-3">
                        <label class="form-label">Amount</label>
                        <input 
                            type="number" 
                            name="amount" 
                            class="form-control" 
                            required
                        >
                    </div>

                    <!-- Type -->
                    <div class="mb-3">
                        <label class="form-label">Type</label>
                        <select name="type" class="form-select">
                            <option value="income">Income</option>
                            <option value="expense">Expense</option>
                        </select>
                    </div>

                    <!-- Category -->
                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <input 
                            type="text" 
                            name="category" 
                            class="form-control" 
                            required
                        >
                    </div>

                    <!-- Note -->
                    <div class="mb-3">
                        <label class="form-label">Note</label>
                        <input 
                            type="text" 
                            name="note" 
                            class="form-control"
                        >
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex justify-content-between">

                        <div>
                            <a href="/api/dashboard" class="btn btn-secondary">
                                Dashboard
                            </a>
                            <a href="/api/records/view" class="btn btn-dark ms-2">
                                Records
                            </a>
                        </div>

                        <button type="submit" class="btn btn-success">
                            Add Record
                        </button>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>