<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Finance Tracker</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark px-3">
        <span class="navbar-brand">Finance Tracker</span>

        <div>

            <% if (user) { %>

                <!-- Role -->
                <span class="text-white me-3">
                    Role: <strong><%= user.role %></strong>
                </span>

                <!-- Admin: Manage Users -->
                <% if (user.role === "admin") { %>
                    <a href="/api/users" class="btn btn-warning btn-sm me-2">
                        Users
                    </a>
                <% } %>

                <!-- Logout -->
                <a href="/api/logout" class="btn btn-danger btn-sm">
                    Logout
                </a>

            <% } else { %>

                <!-- If not logged in -->
                <a href="/api/login" class="btn btn-primary btn-sm me-2">
                    Login
                </a>
                <a href="/api/signup" class="btn btn-success btn-sm">
                    Signup
                </a>

            <% } %>

        </div>
    </nav>

    <!-- Flash Messages -->
    <div class="container mt-3">

        <% if (success && success.length > 0) { %>
            <div class="alert alert-success">
                <%= success %>
            </div>
        <% } %>

        <% if (error && error.length > 0) { %>
            <div class="alert alert-danger">
                <%= error %>
            </div>
        <% } %>

    </div>

    <!-- Main Content -->
    <div class="container mt-4">
        <%- body %>
    </div>

    <!-- Bootstrap JS (optional) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>