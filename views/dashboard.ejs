<% layout("layouts/boilerplate") %>

<h2 class="mb-4">Dashboard</h2>

<div class="row">

    <div class="col-md-4">
        <div class="card text-bg-success mb-3">
            <div class="card-body">
                <h5>Total Income</h5>
                <h3>₹<%= totalIncome %></h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-bg-danger mb-3">
            <div class="card-body">
                <h5>Total Expense</h5>
                <h3>₹<%= totalExpense %></h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-bg-primary mb-3">
            <div class="card-body">
                <h5>Net Balance</h5>
                <h3>₹<%= netBalance %></h3>
            </div>
        </div>
    </div>

</div>

<hr>

<div class="mt-3">
    <a href="/api/records/view" class="btn btn-dark">View Records</a>

    <% if (user.role === "admin") { %>
        <a href="/api/records/new" class="btn btn-primary ms-2">Add Record</a>
    <% } %>
</div>